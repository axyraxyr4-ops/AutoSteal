local GoToBestHub = {}

-- Serviços

local Players = game:GetService("Players")

local RunService = game:GetService("RunService")

local Workspace = game:GetService("Workspace")

local ReplicatedStorage = game:GetService("ReplicatedStorage")

local LocalPlayer = Players.LocalPlayer

-- Configurações do sistema

GoToBestHub.Enabled = false

GoToBestHub.Connections = {}

GoToBestHub.currentBestPet = nil

GoToBestHub.isStopping = false

GoToBestHub.hasReachedHeight = false

GoToBestHub.targetHeight = nil

GoToBestHub.hasSpawned = false

-- Sistema de Grapple Hook sem força

local GrappleHookSystem = {}

GrappleHookSystem.Enabled = false

GrappleHookSystem.Connections = {}

function GrappleHookSystem:equipGrappleHook()

    if not self.Enabled then return nil end

    

    local char = LocalPlayer.Character

    if not char then return nil end

    

    local backpack = LocalPlayer:FindFirstChild("Backpack")

    if not backpack then return nil end

    

    -- Procura pela Grapple Hook

    local grappleHook = backpack:FindFirstChild("Grapple Hook") or char:FindFirstChild("Grapple Hook")

    if not grappleHook then 

        for _, item in ipairs(backpack:GetDescendants()) do

            if item.Name == "Grapple Hook" and item:IsA("Tool") then

                grappleHook = item

                break

            end

        end

        if not grappleHook then return nil end

    end

    

    -- Equipa se estiver no backpack

    if grappleHook.Parent == backpack then

        local humanoid = char:FindFirstChildOfClass("Humanoid")

        if humanoid then

            humanoid:EquipTool(grappleHook)

        end

    end

    

    return grappleHook

end

function GrappleHookSystem:spamGrappleHook()

    if not self.Enabled then return end

    

    -- Método 1: Usar o evento RE/UseItem do jogo

    local REUseItem = ReplicatedStorage:FindFirstChild("Packages")

    if REUseItem then

        REUseItem = REUseItem:FindFirstChild("Net")

        if REUseItem then

            REUseItem = REUseItem:FindFirstChild("RE/UseItem")

            if REUseItem then

                pcall(function()

                    REUseItem:FireServer(0.23450689315795897)

                end)

                return

            end

        end

    end

    

    -- Método 2: Ativar/Desativar a ferramenta

    local char = LocalPlayer.Character

    if not char then return end

    

    local grappleHook = char:FindFirstChild("Grapple Hook")

    if grappleHook and grappleHook:IsA("Tool") then

        pcall(function()

            grappleHook:Activate()

            task.wait(0.05)

            grappleHook:Deactivate()

        end)

    end

end

function GrappleHookSystem:cleanStop()

    self.Enabled = false

    for name, conn in pairs(self.Connections) do

        if conn then

            pcall(function() conn:Disconnect() end)

        end

    end

    self.Connections = {}

end

function GrappleHookSystem:start()

    self:cleanStop()

    self.Enabled = true

    

    self.Connections.equip = RunService.Heartbeat:Connect(function()

        if not self.Enabled then return end

        self:equipGrappleHook()

    end)

    

    self.Connections.spam = RunService.Heartbeat:Connect(function()

        if not self.Enabled then return end

        self:spamGrappleHook()

    end)

end

function GrappleHookSystem:stop()

    self:cleanStop()

end

-- Funções do GoToBestHub

function GoToBestHub:extractValue(text)

    if not text then return 0 end

    local clean = text:gsub("[%$,/s]", ""):gsub(",", "")

    local mult = 1

    if clean:match("[kK]") then

        mult = 1e3

        clean = clean:gsub("[kK]", "")

    elseif clean:match("[mM]") then

        mult = 1e6

        clean = clean:gsub("[mM]", "")

    elseif clean:match("[bB]") then

        mult = 1e9

        clean = clean:gsub("[bB]", "")

    elseif clean:match("[tT]") then

        mult = 1e12

        clean = clean:gsub("[tT]", "")

    end

    local num = tonumber(clean)

    return num and num * mult or 0

end

function GoToBestHub:findMostExpensiveBrainrot()

    if self.isStopping then return nil end

    local allPets = {}

    for _, obj in ipairs(Workspace:GetDescendants()) do

        if self.isStopping then break end

        if obj.Name == "AnimalOverhead" then

            local petValue, petName = 0, "Brainrot"

            for _, child in ipairs(obj:GetChildren()) do

                if child:IsA("TextLabel") then

                    local text = child.Text

                    if text and text:find("$") and text:find("/s") then

                        petValue = self:extractValue(text)

                    end

                    if child.Name == "DisplayName" and text ~= "" then

                        petName = text

                    end

                end

            end

            local position = nil

            local current = obj.Parent

            while current and current ~= Workspace do

                if current:IsA("BasePart") then

                    position = current.Position

                    break

                end

                current = current.Parent

            end

            if position and petValue > 0 then

                table.insert(allPets, {position = position, name = petName, value = petValue})

            end

        end

    end

    if #allPets > 0 and not self.isStopping then

        table.sort(allPets, function(a, b) return a.value > b.value end)

        local bestPet = allPets[1]

        print("MOST EXPENSIVE: " .. bestPet.name .. " - $" .. bestPet.value .. "/s")

        return bestPet

    end

    return nil

end

function GoToBestHub:flyToPosition(targetPos, speed)

    if self.isStopping then return 0 end

    local char = LocalPlayer.Character

    if not char then return 0 end

    local hrp = char:FindFirstChild("HumanoidRootPart")

    if not hrp then return 0 end

    

    local direction = (targetPos - hrp.Position)

    if direction.Magnitude > 0 then

        direction = direction.Unit

    else

        direction = Vector3.new(0,0,0)

    end

    

    hrp.AssemblyLinearVelocity = direction * speed

    return (hrp.Position - targetPos).Magnitude

end

function GoToBestHub:stabilizePlayer()

    local char = LocalPlayer.Character

    if not char then return end

    local hrp = char:FindFirstChild("HumanoidRootPart")

    if not hrp then return end

    hrp.AssemblyLinearVelocity = Vector3.new(0, 0, 0)

end

function GoToBestHub:cleanStop()

    print("STOPPING EVERYTHING...")

    self.isStopping = true

    self.hasReachedHeight = false

    self.targetHeight = nil

    self.hasSpawned = false

    

    -- Para o sistema de Grapple Hook

    GrappleHookSystem:stop()

    

    for name, conn in pairs(self.Connections) do

        if conn then

            conn:Disconnect()

            self.Connections[name] = nil

        end

    end

    

    self.currentBestPet = nil

    self:stabilizePlayer()

    task.wait(0.1)

    self.isStopping = false

    print("SUCCESSFULLY STOPPED!")

end

function GoToBestHub:startGoToBest()

    print("STARTING GO TO BEST!")

    self.isStopping = false

    self.hasReachedHeight = false

    self.targetHeight = nil

    self.hasSpawned = false

    

    -- Inicia o sistema de Grapple Hook

    GrappleHookSystem:start()

    

    self.currentBestPet = self:findMostExpensiveBrainrot()

    if not self.currentBestPet then

        print("No Brainrot found! Stopping...")

        self:Toggle()

        return

    end

    

    task.wait(0.5)

    

    self.Connections.movement = RunService.Heartbeat:Connect(function()

        if self.isStopping or not self.Enabled then return end

        local char = LocalPlayer.Character

        if not char then return end

        local hrp = char:FindFirstChild("HumanoidRootPart")

        if not hrp then return end

        if not self.hasReachedHeight then

            if not self.targetHeight then

                self.targetHeight = Vector3.new(hrp.Position.X, hrp.Position.Y + 55, hrp.Position.Z)

                print("ASCENDING 55 STUDS...")

            end

            local distanceToHeight = (hrp.Position - self.targetHeight).Magnitude

            if distanceToHeight > 5 then

                self:flyToPosition(self.targetHeight, 100)

            else

                print("REACHED 55 STUDS HEIGHT! Now going to Brainrot...")

                self.hasReachedHeight = true

                self:stabilizePlayer()

            end

        else

            if self.currentBestPet and self.currentBestPet.position then

                local targetPos = self.currentBestPet.position

                local distance = (hrp.Position - targetPos).Magnitude

                local maxSpeed = 200

                local minSpeed = 30

                local speed = math.clamp(distance * 2, minSpeed, maxSpeed)

                self:flyToPosition(targetPos, speed)

                

                if distance < 8 then

                    print("ARRIVED AT BRAINROT! Looking for next...")

                    task.wait(1)

                    if not self.isStopping then

                        self.hasReachedHeight = false

                        self.targetHeight = nil

                        self.hasSpawned = false

                        self.currentBestPet = self:findMostExpensiveBrainrot()

                    end

                end

            else

                if not self.isStopping then

                    self.hasReachedHeight = false

                    self.targetHeight = nil

                    self.hasSpawned = false

                    self.currentBestPet = self:findMostExpensiveBrainrot()

                end

            end

        end

    end)

end

function GoToBestHub:Toggle()

    if self.isStopping then

        print("Waiting for complete stop...")

        return

    end

    self.Enabled = not self.Enabled

    if self.Enabled then

        print("Go to the best: ACTIVATED")

        self:startGoToBest()

    else

        print("Go to the best: DEACTIVATED")

        self:cleanStop()

    end

end

function GoToBestHub:Initialize()

    LocalPlayer.CharacterAdded:Connect(function(char)

        task.wait(1)

        if self.Enabled then

            GrappleHookSystem:equipGrappleHook()

        end

        char:WaitForChild("Humanoid").Died:Connect(function()

            if self.Enabled then

                self.Enabled = false

                self:cleanStop()

                print("Character died - System stopped")

            end

        end)

    end)

end

-- Inicialização

GoToBestHub:Initialize()

print("Go to the Best Hub System Loaded!")

print("Use GoToBestHub:Toggle() to start/stop the system")

-- Retorna o módulo para uso externo

return GoToBestHub
