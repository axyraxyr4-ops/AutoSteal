-- AJOUT : DROP BRAINROT & TP DOWN (fonctions)
-- ============================================================

local dropJumping = false
local dropLastJump = 0

local function DropBrainrot()
    local now = tick()
    if now - dropLastJump < 0.4 then return end
    if dropJumping then return end
    
    local char = Player.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    if not hrp or not hum then return end
    
    dropLastJump = now
    dropJumping = true
    
    local groundPos = hrp.Position
    
    hum:ChangeState(Enum.HumanoidStateType.Jumping)
    hrp.AssemblyLinearVelocity = Vector3.new(
        hrp.AssemblyLinearVelocity.X,
        140,
        hrp.AssemblyLinearVelocity.Z
    )
    
    task.delay(0.18, function()
        if hrp then
            hrp.CFrame = CFrame.new(groundPos)
            hrp.AssemblyLinearVelocity = Vector3.zero
        end
        task.delay(0.1, function()
            dropJumping = false
        end)
    end)
end

local function TP_Down()
    local char = Player.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    if not hrp then return end
    
    local rp = RaycastParams.new()
    rp.FilterType = Enum.RaycastFilterType.Exclude
    rp.FilterDescendantsInstances = {char}
    
    local res = workspace:Raycast(hrp.Position, Vector3.new(0, -2000, 0), rp)
    local targetCF
    
    if res then
        targetCF = CFrame.new(res.Position + Vector3.new(0, 3, 0))
    else
        targetCF = hrp.CFrame * CFrame.new(0, -20, 0)
    end
    
    if hum then hum:ChangeState(Enum.HumanoidStateType.Physics) end
    hrp.CFrame = targetCF
    hrp.AssemblyLinearVelocity = Vector3.zero
    hrp.AssemblyAngularVelocity = Vector3.zero
    
    task.wait(0.02)
    hrp.CFrame = targetCF
    hrp.AssemblyLinearVelocity = Vector3.zero
    
    task.wait(0.05)
    if hum then hum:ChangeState(Enum.HumanoidStateType.Running) end
    hrp.CFrame = targetCF
    hrp.AssemblyLinearVelocity = Vector3.zero
end

